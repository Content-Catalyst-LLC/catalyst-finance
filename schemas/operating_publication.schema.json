{
  "$defs": {
    "OperatingDefinition": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "const": "1.7.0",
          "default": "1.7.0",
          "title": "Contract Version",
          "type": "string"
        },
        "model_id": {
          "const": "catalyst-finance.operating",
          "default": "catalyst-finance.operating",
          "title": "Model Id",
          "type": "string"
        },
        "operating_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Operating Id",
          "type": "string"
        },
        "name": {
          "maxLength": 240,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "maxLength": 4000,
          "title": "Description",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/SourceRevision"
        },
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "period_frequency": {
          "default": "monthly",
          "enum": [
            "monthly",
            "quarterly",
            "annual"
          ],
          "title": "Period Frequency",
          "type": "string"
        },
        "target_operating_profit": {
          "default": 0,
          "title": "Target Operating Profit",
          "type": "number"
        },
        "units": {
          "items": {
            "$ref": "#/$defs/OperatingUnitInput"
          },
          "maxItems": 100,
          "minItems": 1,
          "title": "Units",
          "type": "array"
        }
      },
      "required": [
        "operating_id",
        "name",
        "source",
        "units"
      ],
      "title": "OperatingDefinition",
      "type": "object"
    },
    "OperatingMetadata": {
      "additionalProperties": false,

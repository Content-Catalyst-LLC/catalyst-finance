{
  "$defs": {
    "DemandCurve": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "linear",
            "constant_elasticity",
            "observed"
          ],
          "title": "Kind",
          "type": "string"
        },
        "intercept": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Intercept"
        },
        "slope": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Slope"
        },
        "reference_price": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference Price"
        },
        "reference_quantity": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference Quantity"
        },
        "elasticity": {
          "anyOf": [
            {
              "exclusiveMaximum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Elasticity"
        },
        "observed_points": {
          "items": {
            "$ref": "#/$defs/ObservedDemandPoint"
          },
          "maxItems": 500,
          "title": "Observed Points",
          "type": "array"
        }
      },
      "required": [
        "kind"
      ],
      "title": "DemandCurve",
      "type": "object"
    },
    "DemandSegment": {
      "additionalProperties": false,
      "properties": {
        "segment_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Segment Id",
          "type": "string"
        },
        "label": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "quantity_multiplier": {
          "default": 1,
          "exclusiveMinimum": 0,
          "title": "Quantity Multiplier",
          "type": "number"
        },
        "curve": {
          "$ref": "#/$defs/DemandCurve"
        }
      },
      "required": [
        "segment_id",
        "label",
        "curve"
      ],
      "title": "DemandSegment",
      "type": "object"
    },
    "ObservedDemandPoint": {
      "additionalProperties": false,
      "properties": {
        "price": {
          "exclusiveMinimum": 0,
          "title": "Price",
          "type": "number"
        },
        "quantity": {
          "minimum": 0,
          "title": "Quantity",
          "type": "number"
        }
      },
      "required": [
        "price",
        "quantity"
      ],
      "title": "ObservedDemandPoint",
      "type": "object"
    },
    "PriceResult": {
      "additionalProperties": false,
      "properties": {
        "price": {
          "title": "Price",
          "type": "number"
        },
        "segments": {
          "items": {
            "$ref": "#/$defs/SegmentPriceResult"
          },
          "title": "Segments",
          "type": "array"
        },
        "unconstrained_quantity": {
          "title": "Unconstrained Quantity",
          "type": "number"
        },
        "quantity": {
          "title": "Quantity",
          "type": "number"
        },
        "gross_revenue": {
          "title": "Gross Revenue",
          "type": "number"
        },
        "variable_cost": {
          "title": "Variable Cost",
          "type": "number"
        },
        "contribution": {
          "title": "Contribution",
          "type": "number"
        },
        "operating_profit": {
          "title": "Operating Profit",
          "type": "number"
        },
        "contribution_margin_percent": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Contribution Margin Percent"
        },
        "average_elasticity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Average Elasticity"
        },
        "capacity_constrained": {
          "title": "Capacity Constrained",
          "type": "boolean"
        },
        "minimum_volume_met": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Minimum Volume Met"
        },
        "break_even_quantity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Break Even Quantity"
        },
        "break_even_met": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Break Even Met"
        }
      },
      "required": [
        "price",
        "segments",
        "unconstrained_quantity",
        "quantity",
        "gross_revenue",
        "variable_cost",
        "contribution",
        "operating_profit",
        "contribution_margin_percent",
        "average_elasticity",
        "capacity_constrained",
        "minimum_volume_met",
        "break_even_quantity",
        "break_even_met"
      ],
      "title": "PriceResult",
      "type": "object"
    },
    "PricingConstraints": {
      "additionalProperties": false,
      "properties": {
        "capacity_units": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Capacity Units"
        },
        "minimum_volume_units": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum Volume Units"
        },
        "maximum_price_change_percent": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Price Change Percent"
        }
      },
      "title": "PricingConstraints",
      "type": "object"
    },
    "PricingCostStructure": {
      "additionalProperties": false,
      "properties": {
        "fixed_cost": {
          "default": 0,
          "minimum": 0,
          "title": "Fixed Cost",
          "type": "number"
        },
        "unit_variable_cost": {
          "default": 0,
          "minimum": 0,
          "title": "Unit Variable Cost",
          "type": "number"
        },
        "unit_fulfillment_cost": {
          "default": 0,
          "minimum": 0,
          "title": "Unit Fulfillment Cost",
          "type": "number"
        },
        "channel_fee_percent": {
          "default": 0,
          "exclusiveMaximum": 100,
          "minimum": 0,
          "title": "Channel Fee Percent",
          "type": "number"
        }
      },
      "title": "PricingCostStructure",
      "type": "object"
    },
    "PricingDefinition": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "const": "1.8.0",
          "default": "1.8.0",
          "title": "Contract Version",
          "type": "string"
        },
        "model_id": {
          "const": "catalyst-finance.pricing",
          "default": "catalyst-finance.pricing",
          "title": "Model Id",
          "type": "string"
        },
        "pricing_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Pricing Id",
          "type": "string"
        },
        "name": {
          "maxLength": 240,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "maxLength": 4000,
          "title": "Description",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/SourceRevision"
        },
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "objective": {
          "default": "profit",
          "enum": [
            "revenue",
            "contribution",
            "profit"
          ],
          "title": "Objective",
          "type": "string"
        },
        "current_price": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Price"
        },
        "segments": {
          "items": {
            "$ref": "#/$defs/DemandSegment"
          },
          "maxItems": 50,
          "minItems": 1,
          "title": "Segments",
          "type": "array"
        },
        "costs": {
          "$ref": "#/$defs/PricingCostStructure"
        },
        "grid": {
          "$ref": "#/$defs/PricingGrid"
        },
        "constraints": {
          "$ref": "#/$defs/PricingConstraints"
        }
      },
      "required": [
        "pricing_id",
        "name",
        "source",
        "segments",
        "grid"
      ],
      "title": "PricingDefinition",
      "type": "object"
    },
    "PricingGrid": {
      "additionalProperties": false,
      "properties": {
        "minimum_price": {
          "exclusiveMinimum": 0,
          "title": "Minimum Price",
          "type": "number"
        },
        "maximum_price": {
          "exclusiveMinimum": 0,
          "title": "Maximum Price",
          "type": "number"
        },
        "steps": {
          "default": 41,
          "maximum": 1001,
          "minimum": 3,
          "title": "Steps",
          "type": "integer"
        }
      },
      "required": [
        "minimum_price",
        "maximum_price"
      ],
      "title": "PricingGrid",
      "type": "object"
    },
    "PricingMetadata": {
      "additionalProperties": false,
      "properties": {
        "generated_at": {
          "title": "Generated At",
          "type": "string"
        },
        "version": {
          "const": "1.8.0",
          "default": "1.8.0",
          "title": "Version",
          "type": "string"
        },
        "grid_rows": {
          "title": "Grid Rows",
          "type": "integer"
        },
        "constrained_rows": {
          "title": "Constrained Rows",
          "type": "integer"
        },
        "disclaimer": {
          "title": "Disclaimer",
          "type": "string"
        }
      },
      "required": [
        "generated_at",
        "grid_rows",
        "constrained_rows",
        "disclaimer"
      ],
      "title": "PricingMetadata",
      "type": "object"
    },
    "PricingMethodology": {
      "additionalProperties": false,
      "properties": {
        "model_id": {
          "const": "catalyst-finance.pricing",
          "default": "catalyst-finance.pricing",
          "title": "Model Id",
          "type": "string"
        },
        "model_version": {
          "const": "1.8.0",
          "default": "1.8.0",
          "title": "Model Version",
          "type": "string"
        },
        "grid_policy": {
          "const": "inclusive_even_price_grid",
          "default": "inclusive_even_price_grid",
          "title": "Grid Policy",
          "type": "string"
        },
        "observed_policy": {
          "const": "piecewise_linear_with_endpoint_clamping",
          "default": "piecewise_linear_with_endpoint_clamping",
          "title": "Observed Policy",
          "type": "string"
        },
        "capacity_policy": {
          "const": "proportional_segment_allocation",
          "default": "proportional_segment_allocation",
          "title": "Capacity Policy",
          "type": "string"
        },
        "optimum_tie_policy": {
          "const": "lowest_price",
          "default": "lowest_price",
          "title": "Optimum Tie Policy",
          "type": "string"
        },
        "elasticity_policy": {
          "const": "point_linear_constant_or_local_observed_quantity_weighted",
          "default": "point_linear_constant_or_local_observed_quantity_weighted",
          "title": "Elasticity Policy",
          "type": "string"
        }
      },
      "title": "PricingMethodology",
      "type": "object"
    },
    "PricingOptimum": {
      "additionalProperties": false,
      "properties": {
        "objective": {
          "enum": [
            "revenue",
            "contribution",
            "profit"
          ],
          "title": "Objective",
          "type": "string"
        },
        "price": {
          "title": "Price",
          "type": "number"
        },
        "quantity": {
          "title": "Quantity",
          "type": "number"
        },
        "value": {
          "title": "Value",
          "type": "number"
        },
        "row_index": {
          "title": "Row Index",
          "type": "integer"
        }
      },
      "required": [
        "objective",
        "price",
        "quantity",
        "value",
        "row_index"
      ],
      "title": "PricingOptimum",
      "type": "object"
    },
    "PricingRecommendation": {
      "additionalProperties": false,
      "properties": {
        "objective": {
          "enum": [
            "revenue",
            "contribution",
            "profit"
          ],
          "title": "Objective",
          "type": "string"
        },
        "current_price": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Current Price"
        },
        "recommended_price": {
          "title": "Recommended Price",
          "type": "number"
        },
        "absolute_price_change": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Absolute Price Change"
        },
        "percent_price_change": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Percent Price Change"
        },
        "current_objective_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Current Objective Value"
        },
        "recommended_objective_value": {
          "title": "Recommended Objective Value",
          "type": "number"
        },
        "expected_objective_gain": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Expected Objective Gain"
        },
        "constraint_limited": {
          "title": "Constraint Limited",
          "type": "boolean"
        },
        "narrative": {
          "title": "Narrative",
          "type": "string"
        }
      },
      "required": [
        "objective",
        "current_price",
        "recommended_price",
        "absolute_price_change",
        "percent_price_change",
        "current_objective_value",
        "recommended_objective_value",
        "expected_objective_gain",
        "constraint_limited",
        "narrative"
      ],
      "title": "PricingRecommendation",
      "type": "object"
    },
    "SegmentPriceResult": {
      "additionalProperties": false,
      "properties": {
        "segment_id": {
          "title": "Segment Id",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "unconstrained_quantity": {
          "title": "Unconstrained Quantity",
          "type": "number"
        },
        "quantity": {
          "title": "Quantity",
          "type": "number"
        },
        "elasticity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Elasticity"
        },
        "demand_classification": {
          "title": "Demand Classification",
          "type": "string"
        },
        "interpolation_policy": {
          "title": "Interpolation Policy",
          "type": "string"
        }
      },
      "required": [
        "segment_id",
        "label",
        "unconstrained_quantity",
        "quantity",
        "elasticity",
        "demand_classification",
        "interpolation_policy"
      ],
      "title": "SegmentPriceResult",
      "type": "object"
    },
    "SourceRevision": {
      "additionalProperties": false,
      "properties": {
        "workspace_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Workspace Id",
          "type": "string"
        },
        "scenario_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Scenario Id",
          "type": "string"
        },
        "revision_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Revision Id",
          "type": "string"
        },
        "revision_number": {
          "minimum": 1,
          "title": "Revision Number",
          "type": "integer"
        }
      },
      "required": [
        "workspace_id",
        "scenario_id",
        "revision_id",
        "revision_number"
      ],
      "title": "SourceRevision",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "1.8.0",
      "default": "1.8.0",
      "title": "Contract Version",
      "type": "string"
    },
    "model_id": {
      "const": "catalyst-finance.pricing",
      "default": "catalyst-finance.pricing",
      "title": "Model Id",
      "type": "string"
    },
    "definition": {
      "$ref": "#/$defs/PricingDefinition"
    },
    "rows": {
      "items": {
        "$ref": "#/$defs/PriceResult"
      },
      "minItems": 3,
      "title": "Rows",
      "type": "array"
    },
    "current_position": {
      "anyOf": [
        {
          "$ref": "#/$defs/PriceResult"
        },
        {
          "type": "null"
        }
      ]
    },
    "optima": {
      "items": {
        "$ref": "#/$defs/PricingOptimum"
      },
      "maxItems": 3,
      "minItems": 3,
      "title": "Optima",
      "type": "array"
    },
    "recommendation": {
      "$ref": "#/$defs/PricingRecommendation"
    },
    "flags": {
      "items": {
        "type": "string"
      },
      "title": "Flags",
      "type": "array"
    },
    "methodology": {
      "$ref": "#/$defs/PricingMethodology"
    },
    "metadata": {
      "$ref": "#/$defs/PricingMetadata"
    }
  },
  "required": [
    "definition",
    "rows",
    "current_position",
    "optima",
    "recommendation",
    "flags",
    "methodology",
    "metadata"
  ],
  "title": "PricingPublication",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-finance/1.8.0/pricing_publication.schema.json"
}

{
  "$defs": {
    "NaturalCapitalAssetInput": {
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Asset Id",
          "type": "string"
        },
        "label": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "category": {
          "enum": [
            "water",
            "biodiversity",
            "soil",
            "forest",
            "ecosystem_service",
            "other"
          ],
          "title": "Category",
          "type": "string"
        },
        "quantity": {
          "minimum": 0,
          "title": "Quantity",
          "type": "number"
        },
        "unit": {
          "maxLength": 80,
          "minLength": 1,
          "title": "Unit",
          "type": "string"
        },
        "baseline_unit_value": {
          "minimum": 0,
          "title": "Baseline Unit Value",
          "type": "number"
        },
        "projected_unit_value": {
          "minimum": 0,
          "title": "Projected Unit Value",
          "type": "number"
        },
        "annual_service_value": {
          "default": 0,
          "minimum": 0,
          "title": "Annual Service Value",
          "type": "number"
        },
        "restoration_cost": {
          "default": 0,
          "minimum": 0,
          "title": "Restoration Cost",
          "type": "number"
        },
        "confidence_percent": {
          "default": 100,
          "maximum": 100,
          "minimum": 0,
          "title": "Confidence Percent",
          "type": "number"
        }
      },
      "required": [
        "asset_id",
        "label",
        "category",
        "quantity",
        "unit",
        "baseline_unit_value",
        "projected_unit_value"
      ],
      "title": "NaturalCapitalAssetInput",
      "type": "object"
    },
    "SourceRevision": {
      "additionalProperties": false,
      "properties": {
        "workspace_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Workspace Id",
          "type": "string"
        },
        "scenario_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Scenario Id",
          "type": "string"
        },
        "revision_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Revision Id",
          "type": "string"
        },
        "revision_number": {
          "minimum": 1,
          "title": "Revision Number",
          "type": "integer"
        }
      },
      "required": [
        "workspace_id",
        "scenario_id",
        "revision_id",
        "revision_number"
      ],
      "title": "SourceRevision",
      "type": "object"
    },
    "TransitionItemInput": {
      "additionalProperties": false,
      "properties": {
        "item_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Item Id",
          "type": "string"
        },
        "label": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "kind": {
          "enum": [
            "benefit",
            "cost"
          ],
          "title": "Kind",
          "type": "string"
        },
        "amount": {
          "minimum": 0,
          "title": "Amount",
          "type": "number"
        },
        "probability_percent": {
          "default": 100,
          "maximum": 100,
          "minimum": 0,
          "title": "Probability Percent",
          "type": "number"
        },
        "timing_years": {
          "default": 0,
          "minimum": 0,
          "title": "Timing Years",
          "type": "number"
        }
      },
      "required": [
        "item_id",
        "label",
        "kind",
        "amount"
      ],
      "title": "TransitionItemInput",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "1.8.0",
      "default": "1.8.0",
      "title": "Contract Version",
      "type": "string"
    },
    "model_id": {
      "const": "catalyst-finance.sustainable",
      "default": "catalyst-finance.sustainable",
      "title": "Model Id",
      "type": "string"
    },
    "analysis_id": {
      "maxLength": 100,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_-]+$",
      "title": "Analysis Id",
      "type": "string"
    },
    "name": {
      "maxLength": 240,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "description": {
      "default": "",
      "maxLength": 4000,
      "title": "Description",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/SourceRevision"
    },
    "currency": {
      "default": "USD",
      "pattern": "^[A-Z]{3}$",
      "title": "Currency",
      "type": "string"
    },
    "reporting_period": {
      "maxLength": 120,
      "minLength": 1,
      "title": "Reporting Period",
      "type": "string"
    },
    "horizon_years": {
      "default": 10,
      "exclusiveMinimum": 0,
      "maximum": 100,
      "title": "Horizon Years",
      "type": "number"
    },
    "discount_rate_percent": {
      "default": 5,
      "exclusiveMinimum": -100,
      "maximum": 100,
      "title": "Discount Rate Percent",
      "type": "number"
    },
    "base_project_npv": {
      "default": 0,
      "title": "Base Project Npv",
      "type": "number"
    },
    "baseline_emissions_tco2e": {
      "minimum": 0,
      "title": "Baseline Emissions Tco2E",
      "type": "number"
    },
    "project_emissions_tco2e": {
      "minimum": 0,
      "title": "Project Emissions Tco2E",
      "type": "number"
    },
    "carbon_price_per_tco2e": {
      "minimum": 0,
      "title": "Carbon Price Per Tco2E",
      "type": "number"
    },
    "carbon_credit_quantity_tco2e": {
      "default": 0,
      "minimum": 0,
      "title": "Carbon Credit Quantity Tco2E",
      "type": "number"
    },
    "carbon_credit_price_per_tco2e": {
      "default": 0,
      "minimum": 0,
      "title": "Carbon Credit Price Per Tco2E",
      "type": "number"
    },
    "carbon_credit_discount_percent": {
      "default": 0,
      "maximum": 100,
      "minimum": 0,
      "title": "Carbon Credit Discount Percent",
      "type": "number"
    },
    "verification_cost": {
      "default": 0,
      "minimum": 0,
      "title": "Verification Cost",
      "type": "number"
    },
    "carbon_valuation_method": {
      "default": "shadow_price",
      "enum": [
        "shadow_price",
        "market_credit",
        "higher_of",
        "lower_of"
      ],
      "title": "Carbon Valuation Method",
      "type": "string"
    },
    "natural_capital_assets": {
      "items": {
        "$ref": "#/$defs/NaturalCapitalAssetInput"
      },
      "maxItems": 200,
      "title": "Natural Capital Assets",
      "type": "array"
    },
    "transition_items": {
      "items": {
        "$ref": "#/$defs/TransitionItemInput"
      },
      "maxItems": 200,
      "title": "Transition Items",
      "type": "array"
    },
    "green_financing_principal": {
      "default": 0,
      "minimum": 0,
      "title": "Green Financing Principal",
      "type": "number"
    },
    "conventional_interest_rate_percent": {
      "default": 0,
      "maximum": 100,
      "minimum": 0,
      "title": "Conventional Interest Rate Percent",
      "type": "number"
    },
    "green_interest_rate_percent": {
      "default": 0,
      "maximum": 100,
      "minimum": 0,
      "title": "Green Interest Rate Percent",
      "type": "number"
    },
    "financing_term_years": {
      "default": 0,
      "maximum": 100,
      "minimum": 0,
      "title": "Financing Term Years",
      "type": "number"
    }
  },
  "required": [
    "analysis_id",
    "name",
    "source",
    "reporting_period",
    "baseline_emissions_tco2e",
    "project_emissions_tco2e",
    "carbon_price_per_tco2e"
  ],
  "title": "SustainableDefinition",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-finance/1.8.0/sustainable_definition.schema.json"
}

{
  "$defs": {
    "CashFlowContext": {
      "additionalProperties": false,
      "properties": {
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "price_basis": {
          "default": "nominal",
          "enum": [
            "nominal",
            "real"
          ],
          "title": "Price Basis",
          "type": "string"
        },
        "discount_rate_basis": {
          "default": "nominal",
          "enum": [
            "nominal",
            "real"
          ],
          "title": "Discount Rate Basis",
          "type": "string"
        },
        "period_frequency": {
          "default": "annual",
          "enum": [
            "monthly",
            "quarterly",
            "annual"
          ],
          "title": "Period Frequency",
          "type": "string"
        },
        "time_basis": {
          "const": "end_of_period",
          "default": "end_of_period",
          "title": "Time Basis",
          "type": "string"
        },
        "rounding_policy": {
          "const": "half_up",
          "default": "half_up",
          "title": "Rounding Policy",
          "type": "string"
        },
        "monetary_decimals": {
          "default": 2,
          "maximum": 6,
          "minimum": 0,
          "title": "Monetary Decimals",
          "type": "integer"
        },
        "ratio_decimals": {
          "default": 4,
          "maximum": 6,
          "minimum": 0,
          "title": "Ratio Decimals",
          "type": "integer"
        }
      },
      "title": "CashFlowContext",
      "type": "object"
    },
    "CashFlowLine": {
      "additionalProperties": false,
      "properties": {
        "flow_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Flow Id",
          "type": "string"
        },
        "label": {
          "maxLength": 240,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "category": {
          "enum": [
            "capital_cost",
            "operating_cost",
            "revenue",
            "savings",
            "avoided_cost",
            "grant",
            "rebate",
            "residual_value",
            "decommissioning_cost",
            "working_capital",
            "working_capital_recovery",
            "other_benefit",
            "other_cost"
          ],
          "title": "Category",
          "type": "string"
        },
        "amount": {
          "minimum": 0,
          "title": "Amount",
          "type": "number",
          "x-unit": "currency"
        },
        "start_period": {
          "minimum": 0,
          "title": "Start Period",
          "type": "integer"
        },
        "end_period": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Period"
        },
        "interval_periods": {
          "default": 1,
          "minimum": 1,
          "title": "Interval Periods",
          "type": "integer"
        },
        "escalation_rate_percent_annual": {
          "default": 0,
          "exclusiveMinimum": -100,
          "maximum": 1000,
          "title": "Escalation Rate Percent Annual",
          "type": "number",
          "x-unit": "percent_per_year"
        },
        "price_basis": {
          "default": "nominal",
          "enum": [
            "nominal",
            "real"
          ],
          "title": "Price Basis",
          "type": "string"
        },
        "notes": {
          "default": "",
          "maxLength": 4000,
          "title": "Notes",
          "type": "string"
        }
      },
      "required": [
        "flow_id",
        "label",
        "category",
        "amount",
        "start_period"
      ],
      "title": "CashFlowLine",
      "type": "object"
    },
    "CashFlowScenarioInput": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "const": "2.0.0",
          "default": "2.0.0",
          "title": "Contract Version",
          "type": "string"
        },
        "model_id": {
          "const": "catalyst-finance.cash-flow",
          "default": "catalyst-finance.cash-flow",
          "title": "Model Id",
          "type": "string"
        },
        "project": {
          "$ref": "#/$defs/FinanceProject"
        },
        "context": {
          "$ref": "#/$defs/CashFlowContext"
        },
        "analysis_horizon_periods": {
          "maximum": 1200,
          "minimum": 1,
          "title": "Analysis Horizon Periods",
          "type": "integer"
        },
        "discount_rate_percent_annual": {
          "exclusiveMinimum": -100,
          "maximum": 1000,
          "title": "Discount Rate Percent Annual",
          "type": "number",
          "x-unit": "percent_per_year"
        },
        "finance_rate_percent_annual": {
          "default": 0,
          "exclusiveMinimum": -100,
          "maximum": 1000,
          "title": "Finance Rate Percent Annual",
          "type": "number",
          "x-unit": "percent_per_year"
        },
        "reinvestment_rate_percent_annual": {
          "default": 0,
          "exclusiveMinimum": -100,
          "maximum": 1000,
          "title": "Reinvestment Rate Percent Annual",
          "type": "number",
          "x-unit": "percent_per_year"
        },
        "lines": {
          "items": {
            "$ref": "#/$defs/CashFlowLine"
          },
          "maxItems": 1000,
          "minItems": 1,
          "title": "Lines",
          "type": "array"
        }
      },
      "required": [
        "project",
        "analysis_horizon_periods",
        "discount_rate_percent_annual",
        "lines"
      ],
      "title": "CashFlowScenarioInput",
      "type": "object"
    },
    "CorrelationPair": {
      "additionalProperties": false,
      "properties": {
        "left_variable_id": {
          "title": "Left Variable Id",
          "type": "string"
        },
        "right_variable_id": {
          "title": "Right Variable Id",
          "type": "string"
        },
        "coefficient": {
          "exclusiveMaximum": 1,
          "exclusiveMinimum": -1,
          "title": "Coefficient",
          "type": "number"
        }
      },
      "required": [
        "left_variable_id",
        "right_variable_id",
        "coefficient"
      ],
      "title": "CorrelationPair",
      "type": "object"
    },
    "DistributionSpec": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "uniform",
            "triangular",
            "normal",
            "lognormal",
            "discrete"
          ],
          "title": "Kind",
          "type": "string"
        },
        "minimum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum"
        },
        "mode": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mode"
        },
        "maximum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum"
        },
        "mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean"
        },
        "standard_deviation": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Standard Deviation"
        },
        "log_mean": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Log Mean"
        },
        "log_standard_deviation": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Log Standard Deviation"
        },
        "values": {
          "items": {
            "type": "number"
          },
          "maxItems": 100,
          "title": "Values",
          "type": "array"
        },
        "probabilities": {
          "items": {
            "exclusiveMinimum": 0,
            "maximum": 1,
            "type": "number"
          },
          "maxItems": 100,
          "title": "Probabilities",
          "type": "array"
        },
        "truncate_minimum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Truncate Minimum"
        },
        "truncate_maximum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Truncate Maximum"
        }
      },
      "required": [
        "kind"
      ],
      "title": "DistributionSpec",
      "type": "object"
    },
    "FinanceProject": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "maxLength": 200,
          "minLength": 1,

{
  "$defs": {
    "CarbonResult": {
      "additionalProperties": false,
      "properties": {
        "baseline_emissions_tco2e": {
          "title": "Baseline Emissions Tco2E",
          "type": "number"
        },
        "project_emissions_tco2e": {
          "title": "Project Emissions Tco2E",
          "type": "number"
        },
        "avoided_emissions_tco2e": {
          "title": "Avoided Emissions Tco2E",
          "type": "number"
        },
        "emissions_reduction_percent": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Emissions Reduction Percent"
        },
        "shadow_carbon_value": {
          "title": "Shadow Carbon Value",
          "type": "number"
        },
        "eligible_credit_quantity_tco2e": {
          "title": "Eligible Credit Quantity Tco2E",
          "type": "number"
        },
        "gross_market_credit_value": {
          "title": "Gross Market Credit Value",
          "type": "number"
        },
        "discounted_market_credit_value": {
          "title": "Discounted Market Credit Value",
          "type": "number"
        },
        "verification_cost": {
          "title": "Verification Cost",
          "type": "number"
        },
        "net_market_credit_value": {
          "title": "Net Market Credit Value",
          "type": "number"
        },
        "selected_carbon_value": {
          "title": "Selected Carbon Value",
          "type": "number"
        },
        "valuation_method": {
          "enum": [
            "shadow_price",
            "market_credit",
            "higher_of",
            "lower_of"
          ],
          "title": "Valuation Method",
          "type": "string"
        },
        "implied_abatement_cost_per_tco2e": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Implied Abatement Cost Per Tco2E"
        }
      },
      "required": [
        "baseline_emissions_tco2e",
        "project_emissions_tco2e",
        "avoided_emissions_tco2e",
        "emissions_reduction_percent",
        "shadow_carbon_value",
        "eligible_credit_quantity_tco2e",
        "gross_market_credit_value",
        "discounted_market_credit_value",
        "verification_cost",
        "net_market_credit_value",
        "selected_carbon_value",
        "valuation_method",
        "implied_abatement_cost_per_tco2e"
      ],
      "title": "CarbonResult",
      "type": "object"
    },
    "NaturalCapitalAssetInput": {
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Asset Id",
          "type": "string"
        },
        "label": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "category": {
          "enum": [
            "water",
            "biodiversity",
            "soil",
            "forest",
            "ecosystem_service",
            "other"
          ],
          "title": "Category",
          "type": "string"
        },
        "quantity": {
          "minimum": 0,
          "title": "Quantity",
          "type": "number"
        },
        "unit": {
          "maxLength": 80,
          "minLength": 1,
          "title": "Unit",
          "type": "string"
        },
        "baseline_unit_value": {
          "minimum": 0,
          "title": "Baseline Unit Value",
          "type": "number"
        },
        "projected_unit_value": {
          "minimum": 0,
          "title": "Projected Unit Value",
          "type": "number"
        },
        "annual_service_value": {
          "default": 0,
          "minimum": 0,
          "title": "Annual Service Value",
          "type": "number"
        },
        "restoration_cost": {
          "default": 0,
          "minimum": 0,
          "title": "Restoration Cost",
          "type": "number"
        },
        "confidence_percent": {
          "default": 100,
          "maximum": 100,
          "minimum": 0,
          "title": "Confidence Percent",
          "type": "number"
        }
      },
      "required": [
        "asset_id",
        "label",
        "category",
        "quantity",
        "unit",
        "baseline_unit_value",
        "projected_unit_value"
      ],
      "title": "NaturalCapitalAssetInput",
      "type": "object"
    },
    "NaturalCapitalAssetResult": {
      "additionalProperties": false,
      "properties": {
        "asset_id": {
          "title": "Asset Id",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "category": {
          "enum": [
            "water",
            "biodiversity",
            "soil",
            "forest",
            "ecosystem_service",
            "other"
          ],
          "title": "Category",
          "type": "string"
        },
        "quantity": {
          "title": "Quantity",
          "type": "number"
        },
        "unit": {
          "title": "Unit",
          "type": "string"
        },
        "baseline_stock_value": {
          "title": "Baseline Stock Value",
          "type": "number"
        },
        "projected_stock_value": {
          "title": "Projected Stock Value",
          "type": "number"
        },
        "gross_stock_uplift": {
          "title": "Gross Stock Uplift",
          "type": "number"
        },
        "confidence_adjusted_stock_uplift": {
          "title": "Confidence Adjusted Stock Uplift",
          "type": "number"
        },
        "annual_service_value": {
          "title": "Annual Service Value",
          "type": "number"
        },
        "service_value_present_value": {
          "title": "Service Value Present Value",
          "type": "number"
        },
        "restoration_cost": {
          "title": "Restoration Cost",
          "type": "number"
        },
        "net_natural_capital_value": {
          "title": "Net Natural Capital Value",
          "type": "number"
        },
        "confidence_percent": {
          "title": "Confidence Percent",
          "type": "number"
        }
      },
      "required": [
        "asset_id",
        "label",
        "category",
        "quantity",
        "unit",
        "baseline_stock_value",
        "projected_stock_value",
        "gross_stock_uplift",
        "confidence_adjusted_stock_uplift",
        "annual_service_value",
        "service_value_present_value",

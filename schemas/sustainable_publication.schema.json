        },
        "probability_adjusted_amount": {
          "title": "Probability Adjusted Amount",
          "type": "number"
        },
        "timing_years": {
          "title": "Timing Years",
          "type": "number"
        },
        "present_value": {
          "title": "Present Value",
          "type": "number"
        },
        "signed_present_value": {
          "title": "Signed Present Value",
          "type": "number"
        }
      },
      "required": [
        "item_id",
        "label",
        "kind",
        "nominal_amount",
        "probability_percent",
        "probability_adjusted_amount",
        "timing_years",
        "present_value",
        "signed_present_value"
      ],

  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "2.0.0",
      "default": "2.0.0",
      "title": "Contract Version",
      "type": "string"
    },
    "model_id": {
      "const": "catalyst-finance.sustainable",
      "default": "catalyst-finance.sustainable",
      "title": "Model Id",
      "type": "string"
    },
    "definition": {
      "$ref": "#/$defs/SustainableDefinition"
    },
    "carbon": {
      "$ref": "#/$defs/CarbonResult"
    },
    "natural_capital_assets": {
      "items": {
        "$ref": "#/$defs/NaturalCapitalAssetResult"
      },
      "title": "Natural Capital Assets",
      "type": "array"
    },
    "transition_items": {
      "items": {
        "$ref": "#/$defs/TransitionItemResult"
      },
      "title": "Transition Items",
      "type": "array"
    },
    "summary": {
      "$ref": "#/$defs/SustainableSummary"
    },
    "flags": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Flags",
      "type": "array"
    },
    "methodology": {
      "$ref": "#/$defs/SustainableMethodology"
    },
    "metadata": {
      "$ref": "#/$defs/SustainableMetadata"
    }
  },
  "required": [
    "definition",
    "carbon",
    "natural_capital_assets",
    "transition_items",
    "summary",
    "flags",
    "methodology",
    "metadata"

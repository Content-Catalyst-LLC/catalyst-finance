{
  "$defs": {
    "FinanceContext": {
      "additionalProperties": false,
      "properties": {
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "price_basis": {
          "default": "nominal",
          "enum": [
            "nominal",
            "real"
          ],
          "title": "Price Basis",
          "type": "string"
        },
        "discount_rate_basis": {
          "default": "nominal",
          "enum": [
            "nominal",
            "real"
          ],
          "title": "Discount Rate Basis",
          "type": "string"
        },
        "period_frequency": {
          "const": "annual",
          "default": "annual",
          "title": "Period Frequency",
          "type": "string"
        },
        "time_basis": {
          "const": "end_of_period",
          "default": "end_of_period",
          "title": "Time Basis",
          "type": "string"
        },
        "rounding_policy": {
          "const": "half_up",
          "default": "half_up",
          "title": "Rounding Policy",
          "type": "string"
        },
        "monetary_decimals": {
          "const": 2,
          "default": 2,
          "title": "Monetary Decimals",
          "type": "integer"
        },
        "ratio_decimals": {
          "const": 2,
          "default": 2,
          "title": "Ratio Decimals",
          "type": "integer"
        },
        "score_decimals": {
          "const": 1,
          "default": 1,
          "title": "Score Decimals",
          "type": "integer"
        }
      },
      "title": "FinanceContext",
      "type": "object"
    },
    "FinanceInputs": {
      "additionalProperties": false,
      "properties": {
        "capital_cost": {
          "minimum": 0,
          "title": "Capital Cost",
          "type": "number",
          "x-unit": "currency"
        },
        "external_funding": {
          "minimum": 0,
          "title": "External Funding",
          "type": "number",
          "x-unit": "currency"
        },
        "annual_savings": {
          "minimum": 0,
          "title": "Annual Savings",
          "type": "number",
          "x-unit": "currency"
        },
        "annual_operating_cost": {
          "minimum": 0,
          "title": "Annual Operating Cost",
          "type": "number",
          "x-unit": "currency"
        },
        "time_horizon_years": {
          "exclusiveMinimum": 0,
          "maximum": 100,
          "title": "Time Horizon Years",
          "type": "number",
          "x-unit": "years"
        },
        "discount_rate_percent": {
          "exclusiveMinimum": -100,
          "maximum": 100,
          "title": "Discount Rate Percent",
          "type": "number",
          "x-unit": "percent_per_year"
        },
        "annual_emissions_reduced_tons": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Annual Emissions Reduced Tons",
          "x-unit": "metric_tons_co2e_per_year"
        },
        "carbon_price_per_ton": {
          "default": 0,
          "minimum": 0,
          "title": "Carbon Price Per Ton",
          "type": "number",
          "x-unit": "currency_per_metric_ton_co2e"
        },
        "confidence_percent": {
          "maximum": 100,
          "minimum": 0,
          "title": "Confidence Percent",
          "type": "number",
          "x-unit": "percent"
        },
        "implementation_risk_percent": {
          "maximum": 100,
          "minimum": 0,
          "title": "Implementation Risk Percent",
          "type": "number",
          "x-unit": "percent"
        }
      },
      "required": [
        "capital_cost",
        "external_funding",
        "annual_savings",
        "annual_operating_cost",
        "time_horizon_years",
        "discount_rate_percent",
        "confidence_percent",
        "implementation_risk_percent"
      ],
      "title": "FinanceInputs",
      "type": "object"
    },
    "FinanceInterpretation": {
      "additionalProperties": false,
      "properties": {
        "risk_level": {
          "enum": [
            "Lower concern",
            "Moderate concern",
            "High concern"
          ],
          "title": "Risk Level",
          "type": "string"
        },
        "flags": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Flags",
          "type": "array"
        }
      },
      "required": [
        "risk_level",
        "flags"
      ],
      "title": "FinanceInterpretation",
      "type": "object"
    },
    "FinanceMetadata": {
      "additionalProperties": false,
      "properties": {
        "generated_at": {
          "title": "Generated At",
          "type": "string"
        },
        "tool": {
          "const": "Catalyst Finance scenario engine",
          "default": "Catalyst Finance scenario engine",
          "title": "Tool",
          "type": "string"
        },
        "version": {
          "const": "1.9.0",
          "default": "1.9.0",
          "title": "Version",
          "type": "string"
        },
        "disclaimer": {
          "title": "Disclaimer",
          "type": "string"
        },
        "migration": {
          "anyOf": [
            {
              "$ref": "#/$defs/MigrationRecord"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "generated_at",
        "disclaimer"
      ],
      "title": "FinanceMetadata",
      "type": "object"
    },
    "FinanceMethodology": {
      "additionalProperties": false,
      "properties": {
        "model_id": {
          "const": "catalyst-finance.screening",
          "default": "catalyst-finance.screening",
          "title": "Model Id",
          "type": "string"
        },
        "model_version": {
          "const": "1.9.0",
          "default": "1.9.0",
          "title": "Model Version",
          "type": "string"
        },
        "calculation_basis": {
          "const": "annual_screening",
          "default": "annual_screening",
          "title": "Calculation Basis",
          "type": "string"
        },
        "fractional_horizon_policy": {
          "const": "prorated_final_period",
          "default": "prorated_final_period",
          "title": "Fractional Horizon Policy",
          "type": "string"
        },
        "overfunding_policy": {
          "const": "net_capital_cost_floor_zero",
          "default": "net_capital_cost_floor_zero",
          "title": "Overfunding Policy",
          "type": "string"
        },
        "zero_cost_ratio_policy": {
          "const": "undefined_null",
          "default": "undefined_null",
          "title": "Zero Cost Ratio Policy",
          "type": "string"
        },
        "missing_emissions_policy": {
          "const": "exclude_carbon_value",
          "default": "exclude_carbon_value",
          "title": "Missing Emissions Policy",
          "type": "string"
        },
        "score_policy": {
          "const": "transparent_weighted_components",
          "default": "transparent_weighted_components",
          "title": "Score Policy",
          "type": "string"
        }
      },
      "title": "FinanceMethodology",
      "type": "object"
    },
    "FinanceNarrative": {
      "additionalProperties": false,
      "properties": {
        "decision_note": {
          "minLength": 1,
          "title": "Decision Note",
          "type": "string"
        },
        "review_boundary": {
          "minLength": 1,
          "title": "Review Boundary",
          "type": "string"
        }
      },
      "required": [
        "decision_note",
        "review_boundary"
      ],
      "title": "FinanceNarrative",
      "type": "object"
    },
    "FinanceProject": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "category": {
          "default": "Sustainability finance",
          "maxLength": 120,
          "minLength": 1,
          "title": "Category",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "FinanceProject",
      "type": "object"
    },
    "FinanceResults": {
      "additionalProperties": false,
      "properties": {
        "net_capital_cost": {
          "title": "Net Capital Cost",
          "type": "number",
          "x-unit": "currency"
        },
        "carbon_value_per_year": {
          "title": "Carbon Value Per Year",
          "type": "number",
          "x-unit": "currency"
        },
        "net_annual_benefit": {
          "title": "Net Annual Benefit",
          "type": "number",
          "x-unit": "currency"
        },
        "present_value_benefits": {
          "title": "Present Value Benefits",
          "type": "number",
          "x-unit": "currency"
        },
        "npv": {
          "title": "Npv",
          "type": "number",
          "x-unit": "currency"
        },
        "payback_years": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Payback Years",
          "x-unit": "years"
        },
        "roi_percent": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Roi Percent",
          "x-unit": "percent"
        },
        "benefit_cost_ratio": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Benefit Cost Ratio"
        },
        "carbon_cost_per_ton": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Carbon Cost Per Ton",
          "x-unit": "currency_per_metric_ton_co2e"
        },
        "risk_adjusted_score": {
          "maximum": 100,
          "minimum": 0,
          "title": "Risk Adjusted Score",
          "type": "number"
        },
        "score_components": {
          "items": {
            "$ref": "#/$defs/ScoreComponent"
          },
          "maxItems": 4,
          "minItems": 4,
          "title": "Score Components",
          "type": "array"
        }
      },
      "required": [
        "net_capital_cost",
        "carbon_value_per_year",
        "net_annual_benefit",
        "present_value_benefits",
        "npv",
        "payback_years",
        "roi_percent",
        "benefit_cost_ratio",
        "carbon_cost_per_ton",
        "risk_adjusted_score",
        "score_components"
      ],
      "title": "FinanceResults",
      "type": "object"
    },
    "MigrationRecord": {
      "additionalProperties": false,
      "properties": {
        "source_contract_version": {
          "title": "Source Contract Version",
          "type": "string"
        },
        "target_contract_version": {
          "const": "1.9.0",
          "default": "1.9.0",
          "title": "Target Contract Version",
          "type": "string"
        },
        "preserved_fields": {
          "items": {
            "type": "string"
          },
          "title": "Preserved Fields",
          "type": "array"
        }
      },
      "required": [
        "source_contract_version",
        "preserved_fields"
      ],
      "title": "MigrationRecord",
      "type": "object"
    },
    "ScoreComponent": {
      "additionalProperties": false,
      "properties": {
        "component_id": {
          "title": "Component Id",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "raw_score": {
          "maximum": 100,
          "minimum": 0,
          "title": "Raw Score",
          "type": "number"
        },
        "weight": {
          "exclusiveMinimum": 0,
          "maximum": 1,
          "title": "Weight",
          "type": "number"
        },
        "weighted_contribution": {
          "maximum": 100,
          "minimum": 0,
          "title": "Weighted Contribution",
          "type": "number"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        }
      },
      "required": [
        "component_id",
        "label",
        "raw_score",
        "weight",
        "weighted_contribution",
        "rationale"
      ],
      "title": "ScoreComponent",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "1.9.0",
      "default": "1.9.0",
      "title": "Contract Version",
      "type": "string"
    },
    "model_id": {
      "const": "catalyst-finance.screening",
      "default": "catalyst-finance.screening",
      "title": "Model Id",
      "type": "string"
    },
    "project": {
      "$ref": "#/$defs/FinanceProject"
    },
    "context": {
      "$ref": "#/$defs/FinanceContext"
    },
    "assumptions": {
      "$ref": "#/$defs/FinanceInputs"
    },
    "results": {
      "$ref": "#/$defs/FinanceResults"
    },
    "interpretation": {
      "$ref": "#/$defs/FinanceInterpretation"
    },
    "narrative": {
      "$ref": "#/$defs/FinanceNarrative"
    },
    "methodology": {
      "$ref": "#/$defs/FinanceMethodology"
    },
    "metadata": {
      "$ref": "#/$defs/FinanceMetadata"
    }
  },
  "required": [
    "project",
    "context",
    "assumptions",
    "results",
    "interpretation",
    "narrative",
    "methodology",
    "metadata"
  ],
  "title": "FinancePublication",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-finance/1.9.0/finance_publication.schema.json"
}

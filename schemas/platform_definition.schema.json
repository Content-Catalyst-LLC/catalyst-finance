{
  "$defs": {
    "ArtifactFinancialSummary": {
      "additionalProperties": false,
      "properties": {
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "base_npv": {
          "default": 0,
          "title": "Base Npv",
          "type": "number"
        },
        "adjusted_npv": {
          "default": 0,
          "title": "Adjusted Npv",
          "type": "number"
        },
        "capital_required": {
          "default": 0,
          "minimum": 0,
          "title": "Capital Required",
          "type": "number"
        },
        "annual_value": {
          "default": 0,
          "title": "Annual Value",
          "type": "number"
        },
        "confidence_percent": {
          "default": 100,
          "maximum": 100,
          "minimum": 0,
          "title": "Confidence Percent",
          "type": "number"
        },
        "downside_probability_percent": {
          "default": 0,
          "maximum": 100,
          "minimum": 0,
          "title": "Downside Probability Percent",
          "type": "number"
        }
      },
      "title": "ArtifactFinancialSummary",
      "type": "object"
    },
    "ConnectedProduct": {
      "additionalProperties": false,
      "properties": {
        "product_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Product Id",
          "type": "string"
        },
        "name": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 80,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        },
        "role": {
          "enum": [
            "finance",
            "decision",
            "knowledge",
            "compute",
            "data",
            "intelligence",
            "research",
            "design",
            "support"
          ],
          "title": "Role",
          "type": "string"
        },
        "status": {
          "default": "online",
          "enum": [
            "online",
            "degraded",
            "offline"
          ],
          "title": "Status",
          "type": "string"
        },
        "artifact_kinds": {
          "items": {
            "type": "string"
          },
          "maxItems": 100,
          "title": "Artifact Kinds",
          "type": "array"
        },
        "supported_contracts": {
          "items": {
            "type": "string"
          },
          "maxItems": 100,
          "title": "Supported Contracts",
          "type": "array"
        },
        "accepted_classifications": {
          "items": {
            "enum": [
              "public",
              "internal",
              "confidential",
              "restricted"
            ],
            "type": "string"
          },
          "minItems": 1,
          "title": "Accepted Classifications",
          "type": "array"
        },
        "api_base": {
          "anyOf": [
            {
              "maxLength": 500,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Api Base"
        }
      },
      "required": [
        "product_id",
        "name",
        "version",
        "role"
      ],
      "title": "ConnectedProduct",
      "type": "object"
    },
    "DecisionCase": {
      "additionalProperties": false,
      "properties": {
        "case_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Case Id",
          "type": "string"
        },
        "name": {
          "maxLength": 240,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "objective": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Objective",
          "type": "string"
        },
        "owner": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Owner",
          "type": "string"
        },
        "status": {
          "default": "active",
          "enum": [
            "draft",
            "active",
            "in_review",
            "decided",
            "archived"
          ],
          "title": "Status",
          "type": "string"
        },
        "priority": {
          "default": "normal",
          "enum": [
            "low",
            "normal",
            "high",
            "critical"
          ],
          "title": "Priority",
          "type": "string"
        },
        "artifact_ids": {
          "items": {
            "maxLength": 120,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.:-]+$",
            "type": "string"
          },
          "maxItems": 100,
          "minItems": 1,
          "title": "Artifact Ids",
          "type": "array"
        },
        "required_product_ids": {
          "items": {
            "maxLength": 120,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.:-]+$",
            "type": "string"
          },
          "maxItems": 50,
          "title": "Required Product Ids",
          "type": "array"
        },
        "decision_packet_id": {
          "anyOf": [
            {
              "maxLength": 120,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9_.:-]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Decision Packet Id"
        },
        "knowledge_collection_id": {
          "anyOf": [
            {
              "maxLength": 120,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9_.:-]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Knowledge Collection Id"
        }
      },
      "required": [
        "case_id",
        "name",
        "objective",
        "owner",
        "artifact_ids"
      ],
      "title": "DecisionCase",
      "type": "object"
    },
    "DependencyEdge": {
      "additionalProperties": false,
      "properties": {
        "edge_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Edge Id",
          "type": "string"
        },
        "upstream_artifact_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Upstream Artifact Id",
          "type": "string"
        },
        "downstream_artifact_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Downstream Artifact Id",
          "type": "string"
        },
        "relationship": {
          "enum": [
            "informs",
            "depends_on",
            "evidence_for",
            "calculation_for",
            "supersedes"
          ],
          "title": "Relationship",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "note": {
          "default": "",
          "maxLength": 1000,
          "title": "Note",
          "type": "string"
        }
      },
      "required": [
        "edge_id",
        "upstream_artifact_id",
        "downstream_artifact_id",
        "relationship"
      ],
      "title": "DependencyEdge",
      "type": "object"
    },
    "HandoffEnvelope": {
      "additionalProperties": false,
      "properties": {
        "handoff_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Handoff Id",
          "type": "string"
        },
        "source_product_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Source Product Id",
          "type": "string"
        },
        "target_product_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Target Product Id",
          "type": "string"
        },
        "artifact_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_revision_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Artifact Revision Id",
          "type": "string"
        },
        "contract_id": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Contract Id",
          "type": "string"
        },
        "classification": {
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ],
          "title": "Classification",
          "type": "string"
        },
        "status": {
          "default": "queued",
          "enum": [
            "queued",
            "accepted",
            "rejected",
            "completed",
            "failed"
          ],
          "title": "Status",
          "type": "string"
        },
        "payload_hash_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Payload Hash Sha256",
          "type": "string"
        },
        "requested_at": {
          "maxLength": 80,
          "minLength": 1,
          "title": "Requested At",
          "type": "string"
        },
        "updated_at": {
          "maxLength": 80,
          "minLength": 1,
          "title": "Updated At",
          "type": "string"
        },
        "destination_id": {
          "anyOf": [
            {
              "maxLength": 120,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9_.:-]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Destination Id"
        },
        "error_code": {
          "anyOf": [
            {
              "maxLength": 120,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Code"
        },
        "note": {
          "default": "",
          "maxLength": 2000,
          "title": "Note",
          "type": "string"
        }
      },
      "required": [
        "handoff_id",
        "source_product_id",
        "target_product_id",
        "artifact_id",
        "artifact_revision_id",
        "contract_id",
        "classification",
        "payload_hash_sha256",
        "requested_at",
        "updated_at"
      ],
      "title": "HandoffEnvelope",
      "type": "object"
    },
    "PlatformArtifact": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Artifact Id",
          "type": "string"
        },
        "revision_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Revision Id",
          "type": "string"
        },
        "source_product_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Source Product Id",
          "type": "string"
        },
        "model_id": {
          "maxLength": 120,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Model Id",
          "type": "string"
        },
        "model_version": {
          "maxLength": 80,
          "minLength": 1,
          "title": "Model Version",
          "type": "string"
        },
        "title": {
          "maxLength": 240,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "artifact_kind": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Artifact Kind",
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "in_review",
            "approved",
            "published",
            "withdrawn"
          ],
          "title": "Status",
          "type": "string"
        },
        "governance_status": {
          "enum": [
            "blocked",
            "ready_for_review",
            "approved",
            "published"
          ],
          "title": "Governance Status",
          "type": "string"
        },
        "classification": {
          "default": "internal",
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ],
          "title": "Classification",
          "type": "string"
        },
        "include_in_portfolio": {
          "default": true,
          "title": "Include In Portfolio",
          "type": "boolean"
        },
        "checksum_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Checksum Sha256",
          "type": "string"
        },
        "financial": {
          "$ref": "#/$defs/ArtifactFinancialSummary"
        },
        "headline_metrics": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "maxProperties": 100,
          "title": "Headline Metrics",
          "type": "object"
        },
        "source_uri": {
          "anyOf": [
            {
              "maxLength": 1000,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Uri"
        }
      },
      "required": [
        "artifact_id",
        "revision_id",
        "source_product_id",
        "model_id",
        "model_version",
        "title",
        "artifact_kind",
        "status",
        "governance_status",
        "checksum_sha256"
      ],
      "title": "PlatformArtifact",
      "type": "object"
    },
    "PlatformPolicy": {
      "additionalProperties": false,
      "properties": {
        "require_governance_for_completed_handoffs": {
          "default": true,
          "title": "Require Governance For Completed Handoffs",
          "type": "boolean"
        },
        "require_approved_artifact_for_completed_handoffs": {
          "default": true,
          "title": "Require Approved Artifact For Completed Handoffs",
          "type": "boolean"
        },
        "require_checksums": {
          "default": true,
          "title": "Require Checksums",
          "type": "boolean"
        },
        "minimum_case_confidence_percent": {
          "default": 70,
          "maximum": 100,
          "minimum": 0,
          "title": "Minimum Case Confidence Percent",
          "type": "number"
        },
        "allowed_public_statuses": {
          "items": {
            "enum": [
              "draft",
              "in_review",
              "approved",
              "published",
              "withdrawn"
            ],
            "type": "string"
          },
          "minItems": 1,
          "title": "Allowed Public Statuses",
          "type": "array"
        }
      },
      "title": "PlatformPolicy",
      "type": "object"
    },
    "SourceRevision": {
      "additionalProperties": false,
      "properties": {
        "workspace_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Workspace Id",
          "type": "string"
        },
        "scenario_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Scenario Id",
          "type": "string"
        },
        "revision_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Revision Id",
          "type": "string"
        },
        "revision_number": {
          "minimum": 1,
          "title": "Revision Number",
          "type": "integer"
        }
      },
      "required": [
        "workspace_id",
        "scenario_id",
        "revision_id",
        "revision_number"
      ],
      "title": "SourceRevision",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "2.0.0",
      "default": "2.0.0",
      "title": "Contract Version",
      "type": "string"
    },
    "model_id": {
      "const": "catalyst-finance.platform",
      "default": "catalyst-finance.platform",
      "title": "Model Id",
      "type": "string"
    },
    "platform_id": {
      "maxLength": 120,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.:-]+$",
      "title": "Platform Id",
      "type": "string"
    },
    "name": {
      "maxLength": 240,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "description": {
      "default": "",
      "maxLength": 4000,
      "title": "Description",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/SourceRevision"
    },
    "products": {
      "items": {
        "$ref": "#/$defs/ConnectedProduct"
      },
      "maxItems": 100,
      "minItems": 2,
      "title": "Products",
      "type": "array"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/PlatformArtifact"
      },
      "maxItems": 1000,
      "minItems": 1,
      "title": "Artifacts",
      "type": "array"
    },
    "cases": {
      "items": {
        "$ref": "#/$defs/DecisionCase"
      },
      "maxItems": 500,
      "minItems": 1,
      "title": "Cases",
      "type": "array"
    },
    "dependencies": {
      "items": {
        "$ref": "#/$defs/DependencyEdge"
      },
      "maxItems": 5000,
      "title": "Dependencies",
      "type": "array"
    },
    "handoffs": {
      "items": {
        "$ref": "#/$defs/HandoffEnvelope"
      },
      "maxItems": 5000,
      "title": "Handoffs",
      "type": "array"
    },
    "policy": {
      "$ref": "#/$defs/PlatformPolicy"
    }
  },
  "required": [
    "platform_id",
    "name",
    "source",
    "products",
    "artifacts",
    "cases"
  ],
  "title": "PlatformDefinition",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-finance/2.0.0/platform_definition.schema.json"
}

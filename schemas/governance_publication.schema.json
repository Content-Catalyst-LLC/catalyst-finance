{
  "$defs": {
    "AssumptionRecord": {
      "additionalProperties": false,
      "properties": {
        "assumption_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Assumption Id",
          "type": "string"
        },
        "label": {
          "maxLength": 240,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "value": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Value",
          "type": "string"
        },
        "unit": {
          "anyOf": [
            {
              "maxLength": 100,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        },
        "owner": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Owner",
          "type": "string"
        },
        "confidence_percent": {
          "default": 100,
          "maximum": 100,
          "minimum": 0,
          "title": "Confidence Percent",
          "type": "number"
        },
        "applicability": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Applicability",
          "type": "string"
        },
        "review_status": {
          "default": "draft",
          "enum": [
            "draft",
            "in_review",
            "verified",
            "rejected"
          ],
          "title": "Review Status",
          "type": "string"
        },
        "source_ids": {
          "items": {
            "maxLength": 100,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.:-]+$",
            "type": "string"
          },
          "maxItems": 50,
          "title": "Source Ids",
          "type": "array"
        },
        "evidence_ids": {
          "items": {
            "maxLength": 100,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.:-]+$",
            "type": "string"
          },
          "maxItems": 50,
          "title": "Evidence Ids",
          "type": "array"
        },
        "private": {
          "default": false,
          "title": "Private",
          "type": "boolean"
        },
        "rationale": {
          "default": "",
          "maxLength": 4000,
          "title": "Rationale",
          "type": "string"
        }
      },
      "required": [
        "assumption_id",
        "label",
        "value",
        "owner",
        "applicability"
      ],
      "title": "AssumptionRecord",
      "type": "object"
    },
    "AttachmentRecord": {
      "additionalProperties": false,
      "properties": {
        "attachment_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Attachment Id",
          "type": "string"
        },
        "filename": {
          "maxLength": 300,
          "minLength": 1,
          "title": "Filename",
          "type": "string"
        },
        "media_type": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "checksum_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Checksum Sha256",
          "type": "string"
        },
        "owner": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Owner",
          "type": "string"
        },
        "private": {
          "default": true,
          "title": "Private",
          "type": "boolean"
        },
        "retention_note": {
          "default": "",
          "maxLength": 1000,
          "title": "Retention Note",
          "type": "string"
        }
      },
      "required": [
        "attachment_id",
        "filename",
        "media_type",
        "checksum_sha256",
        "owner"
      ],
      "title": "AttachmentRecord",
      "type": "object"
    },
    "AuditEntry": {
      "additionalProperties": false,
      "properties": {
        "sequence": {
          "title": "Sequence",
          "type": "integer"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "action": {
          "title": "Action",
          "type": "string"
        },
        "actor_id": {
          "title": "Actor Id",
          "type": "string"
        },
        "subject_id": {
          "title": "Subject Id",
          "type": "string"
        },
        "created_at": {
          "title": "Created At",
          "type": "string"
        },
        "previous_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Previous Hash"
        },
        "entry_hash": {
          "title": "Entry Hash",
          "type": "string"
        }
      },
      "required": [
        "sequence",
        "event_id",
        "action",
        "actor_id",
        "subject_id",
        "created_at",
        "previous_hash",
        "entry_hash"
      ],
      "title": "AuditEntry",
      "type": "object"
    },
    "ClaimRecord": {

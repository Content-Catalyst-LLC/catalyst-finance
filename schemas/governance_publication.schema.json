          "type": "string"
        },
        "model_version": {
          "const": "2.0.0",
          "default": "2.0.0",
          "title": "Model Version",
          "type": "string"
        },
        "trace_policy": {
          "const": "headline_metric_to_assumption_and_evidence",
          "default": "headline_metric_to_assumption_and_evidence",
          "title": "Trace Policy",
          "type": "string"
        },
        "review_policy": {
          "const": "append_only_events_and_unresolved_issue_gate",
          "default": "append_only_events_and_unresolved_issue_gate",
          "title": "Review Policy",
          "type": "string"
        },
        "redaction_policy": {
          "const": "private_records_excluded_from_public_payload",
          "default": "private_records_excluded_from_public_payload",
          "title": "Redaction Policy",
          "type": "string"
        },
        "audit_policy": {
          "const": "sha256_hash_chained_events",
          "default": "sha256_hash_chained_events",
          "title": "Audit Policy",
          "type": "string"
        }
      },
      "title": "GovernanceMethodology",
      "type": "object"
    },

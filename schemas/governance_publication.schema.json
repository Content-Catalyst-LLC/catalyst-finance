        },
        "summary": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "locator": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Locator",
          "type": "string"
        },
        "confidence_percent": {
          "default": 100,
          "maximum": 100,
          "minimum": 0,
          "title": "Confidence Percent",

    "GovernanceDefinition": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "const": "2.0.0",
          "default": "2.0.0",
          "title": "Contract Version",
          "type": "string"
        },
        "model_id": {
          "const": "catalyst-finance.governance",
          "default": "catalyst-finance.governance",
          "title": "Model Id",
          "type": "string"
        },
        "governance_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Governance Id",
          "type": "string"
        },
        "name": {
          "maxLength": 240,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "maxLength": 4000,
          "title": "Description",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/SourceRevision"
        },
        "artifact": {
          "$ref": "#/$defs/GovernedArtifactReference"
        },
        "assumptions": {
          "items": {
            "$ref": "#/$defs/AssumptionRecord"
          },
          "maxItems": 500,
          "title": "Assumptions",
          "type": "array"
        },
        "sources": {
          "items": {
            "$ref": "#/$defs/SourceRecord"
          },
          "maxItems": 500,
          "title": "Sources",
          "type": "array"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceRecord"
          },
          "maxItems": 1000,
          "title": "Evidence",
          "type": "array"
        },
        "claims": {
          "items": {
            "$ref": "#/$defs/ClaimRecord"
          },
          "maxItems": 500,
          "title": "Claims",
          "type": "array"
        },
        "methodologies": {
          "items": {
            "$ref": "#/$defs/MethodologyDeclaration"
          },
          "maxItems": 100,
          "title": "Methodologies",
          "type": "array"
        },
        "review_events": {
          "items": {
            "$ref": "#/$defs/ReviewEvent"
          },
          "maxItems": 2000,
          "title": "Review Events",
          "type": "array"
        },
        "attachments": {
          "items": {
            "$ref": "#/$defs/AttachmentRecord"
          },
          "maxItems": 200,
          "title": "Attachments",
          "type": "array"
        },
        "publication": {
          "$ref": "#/$defs/PublicationControls"
        }
      },
      "required": [
        "governance_id",
        "name",
        "source",
        "artifact",
        "publication"
      ],
      "title": "GovernanceDefinition",
      "type": "object"
    },
    "GovernanceMetadata": {
      "additionalProperties": false,
      "properties": {
        "generated_at": {
          "title": "Generated At",
          "type": "string"

          "type": "array"
        },
        "calculation_ids": {
          "items": {
            "maxLength": 100,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.:-]+$",
            "type": "string"
          },
          "maxItems": 50,
          "title": "Calculation Ids",
          "type": "array"
        },
        "assumption_ids": {
          "items": {
            "maxLength": 100,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.:-]+$",
            "type": "string"
          },
          "maxItems": 50,
          "title": "Assumption Ids",
          "type": "array"
        },
        "source_ids": {
          "items": {
            "maxLength": 100,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.:-]+$",
            "type": "string"
          },
          "maxItems": 50,
          "title": "Source Ids",
          "type": "array"
        },
        "evidence_ids": {
          "items": {
            "maxLength": 100,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.:-]+$",
            "type": "string"
          },
          "maxItems": 50,
          "title": "Evidence Ids",
          "type": "array"
        },
        "review_status": {
          "default": "draft",
          "enum": [
            "draft",
            "in_review",
            "verified",
            "rejected"
          ],
          "title": "Review Status",
          "type": "string"
        },
        "public": {
          "default": true,
          "title": "Public",
          "type": "boolean"
        }
      },
      "required": [
        "claim_id",
        "text"
      ],
      "title": "ClaimRecord",
      "type": "object"
    },
    "EvidenceRecord": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Evidence Id",
          "type": "string"
        },
        "source_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Source Id",
          "type": "string"
        },
        "evidence_type": {
          "enum": [
            "quantitative",
            "qualitative",
            "methodology",
            "assurance",
            "limitation"

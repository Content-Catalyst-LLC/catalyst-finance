          "title": "Evidence Type",
          "type": "string"
        },
        "summary": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "locator": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Locator",
          "type": "string"
        },
        "confidence_percent": {
          "default": 100,
          "maximum": 100,
          "minimum": 0,
          "title": "Confidence Percent",
          "type": "number"
        },
        "private": {
          "default": false,
          "title": "Private",
          "type": "boolean"
        }
      },
      "required": [
        "evidence_id",
        "source_id",
        "evidence_type",
        "summary",
        "locator"
      ],
      "title": "EvidenceRecord",
      "type": "object"
    },
    "GovernedArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Artifact Id",
          "type": "string"
        },
        "model_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Model Id",
          "type": "string"
        },
        "model_version": {
          "maxLength": 40,
          "minLength": 1,
          "title": "Model Version",
          "type": "string"
        },
        "revision_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.:-]+$",
          "title": "Revision Id",
          "type": "string"
        },
        "title": {
          "maxLength": 240,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "headline_metrics": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"

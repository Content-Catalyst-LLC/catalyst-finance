        "audience": {
          "default": "private",
          "enum": [
            "private",
            "internal",
            "public"
          ],
          "title": "Audience",
          "type": "string"
        },
        "title": {
          "maxLength": 240,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "summary": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "redaction_policy": {
          "default": "exclude_private",
          "enum": [
            "exclude_private",
            "none"
          ],
          "title": "Redaction Policy",
          "type": "string"
        },
        "knowledge_library_collection_id": {
          "anyOf": [
            {
              "maxLength": 100,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9_.:-]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Knowledge Library Collection Id"
        },
        "decision_studio_packet_id": {
          "anyOf": [
            {
              "maxLength": 100,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9_.:-]+$",

{
  "$defs": {
    "DemandCurve": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "linear",
            "constant_elasticity",
            "observed"
          ],
          "title": "Kind",
          "type": "string"
        },
        "intercept": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Intercept"
        },
        "slope": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Slope"
        },
        "reference_price": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference Price"
        },
        "reference_quantity": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reference Quantity"
        },
        "elasticity": {
          "anyOf": [
            {
              "exclusiveMaximum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Elasticity"
        },
        "observed_points": {
          "items": {
            "$ref": "#/$defs/ObservedDemandPoint"
          },
          "maxItems": 500,
          "title": "Observed Points",
          "type": "array"
        }
      },
      "required": [
        "kind"
      ],
      "title": "DemandCurve",
      "type": "object"
    },
    "DemandSegment": {
      "additionalProperties": false,
      "properties": {
        "segment_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Segment Id",
          "type": "string"
        },
        "label": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "quantity_multiplier": {
          "default": 1,
          "exclusiveMinimum": 0,
          "title": "Quantity Multiplier",
          "type": "number"
        },
        "curve": {
          "$ref": "#/$defs/DemandCurve"
        }
      },
      "required": [
        "segment_id",
        "label",
        "curve"
      ],
      "title": "DemandSegment",
      "type": "object"
    },
    "ObservedDemandPoint": {
      "additionalProperties": false,
      "properties": {
        "price": {
          "exclusiveMinimum": 0,
          "title": "Price",
          "type": "number"
        },
        "quantity": {
          "minimum": 0,
          "title": "Quantity",
          "type": "number"
        }
      },
      "required": [
        "price",
        "quantity"
      ],
      "title": "ObservedDemandPoint",
      "type": "object"
    },
    "PricingConstraints": {
      "additionalProperties": false,
      "properties": {
        "capacity_units": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Capacity Units"
        },
        "minimum_volume_units": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum Volume Units"
        },
        "maximum_price_change_percent": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Price Change Percent"
        }
      },
      "title": "PricingConstraints",
      "type": "object"
    },
    "PricingCostStructure": {
      "additionalProperties": false,
      "properties": {
        "fixed_cost": {
          "default": 0,
          "minimum": 0,
          "title": "Fixed Cost",
          "type": "number"
        },
        "unit_variable_cost": {
          "default": 0,
          "minimum": 0,
          "title": "Unit Variable Cost",
          "type": "number"
        },
        "unit_fulfillment_cost": {
          "default": 0,
          "minimum": 0,
          "title": "Unit Fulfillment Cost",
          "type": "number"
        },
        "channel_fee_percent": {
          "default": 0,
          "exclusiveMaximum": 100,
          "minimum": 0,
          "title": "Channel Fee Percent",
          "type": "number"
        }
      },
      "title": "PricingCostStructure",
      "type": "object"
    },
    "PricingGrid": {
      "additionalProperties": false,
      "properties": {
        "minimum_price": {
          "exclusiveMinimum": 0,
          "title": "Minimum Price",
          "type": "number"
        },
        "maximum_price": {
          "exclusiveMinimum": 0,
          "title": "Maximum Price",
          "type": "number"
        },
        "steps": {
          "default": 41,
          "maximum": 1001,
          "minimum": 3,
          "title": "Steps",
          "type": "integer"
        }
      },
      "required": [
        "minimum_price",
        "maximum_price"
      ],
      "title": "PricingGrid",
      "type": "object"
    },
    "SourceRevision": {
      "additionalProperties": false,
      "properties": {
        "workspace_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Workspace Id",
          "type": "string"
        },
        "scenario_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Scenario Id",
          "type": "string"
        },
        "revision_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Revision Id",
          "type": "string"
        },
        "revision_number": {
          "minimum": 1,
          "title": "Revision Number",
          "type": "integer"
        }
      },
      "required": [
        "workspace_id",
        "scenario_id",
        "revision_id",
        "revision_number"
      ],
      "title": "SourceRevision",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "1.9.0",
      "default": "1.9.0",
      "title": "Contract Version",
      "type": "string"
    },
    "model_id": {
      "const": "catalyst-finance.pricing",
      "default": "catalyst-finance.pricing",
      "title": "Model Id",
      "type": "string"
    },
    "pricing_id": {
      "maxLength": 100,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_-]+$",
      "title": "Pricing Id",
      "type": "string"
    },
    "name": {
      "maxLength": 240,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "description": {
      "default": "",
      "maxLength": 4000,
      "title": "Description",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/SourceRevision"
    },
    "currency": {
      "default": "USD",
      "pattern": "^[A-Z]{3}$",
      "title": "Currency",
      "type": "string"
    },
    "objective": {
      "default": "profit",
      "enum": [
        "revenue",
        "contribution",
        "profit"
      ],
      "title": "Objective",
      "type": "string"
    },
    "current_price": {
      "anyOf": [
        {
          "exclusiveMinimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Current Price"
    },
    "segments": {
      "items": {
        "$ref": "#/$defs/DemandSegment"
      },
      "maxItems": 50,
      "minItems": 1,
      "title": "Segments",
      "type": "array"
    },
    "costs": {
      "$ref": "#/$defs/PricingCostStructure"
    },
    "grid": {
      "$ref": "#/$defs/PricingGrid"
    },
    "constraints": {
      "$ref": "#/$defs/PricingConstraints"
    }
  },
  "required": [
    "pricing_id",
    "name",
    "source",
    "segments",
    "grid"
  ],
  "title": "PricingDefinition",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-finance/1.9.0/pricing_definition.schema.json"
}

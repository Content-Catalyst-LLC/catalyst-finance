    "CashFlowScenarioInput": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "const": "1.5.0",
          "default": "1.5.0",
          "title": "Contract Version",
          "type": "string"
        },
        "model_id": {
          "const": "catalyst-finance.cash-flow",

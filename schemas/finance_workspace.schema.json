{
  "$defs": {
    "BreakEvenDefinition": {
      "additionalProperties": false,
      "properties": {
        "threshold_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Threshold Id",
          "type": "string"
        },
        "alternative_id": {
          "title": "Alternative Id",
          "type": "string"
        },
        "metric_id": {
          "default": "npv",
          "enum": [
            "npv",
            "net_cash_flow",
            "discounted_payback_periods",
            "irr_percent_annual",
            "mirr_percent_annual",
            "profitability_index",
            "benefit_cost_ratio",
            "equivalent_annual_value"
          ],
          "title": "Metric Id",
          "type": "string"
        },
        "parameter": {
          "$ref": "#/$defs/SensitivityParameter"
        },
        "target_value": {
          "default": 0,
          "title": "Target Value",
          "type": "number"
        },
        "lower_bound": {
          "title": "Lower Bound",
          "type": "number"
        },
        "upper_bound": {
          "title": "Upper Bound",
          "type": "number"
        },
        "tolerance": {
          "default": 0.0001,
          "exclusiveMinimum": 0,
          "title": "Tolerance",
          "type": "number"
        },
        "max_iterations": {
          "default": 100,
          "maximum": 500,
          "minimum": 10,
          "title": "Max Iterations",
          "type": "integer"
        }
      },
      "required": [
        "threshold_id",
        "alternative_id",
        "parameter",
        "lower_bound",
        "upper_bound"
      ],
      "title": "BreakEvenDefinition",
      "type": "object"
    },
    "CashFlowContext": {

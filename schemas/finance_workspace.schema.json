      "type": "object"
    },
    "ComparisonAlternative": {
      "additionalProperties": false,
      "properties": {
        "alternative_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",

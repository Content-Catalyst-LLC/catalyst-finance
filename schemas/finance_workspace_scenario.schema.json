{
  "$defs": {
    "CashFlowContext": {
      "additionalProperties": false,
      "properties": {
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "price_basis": {
          "default": "nominal",
          "enum": [
            "nominal",
            "real"
          ],
          "title": "Price Basis",
          "type": "string"
        },
        "discount_rate_basis": {
          "default": "nominal",
          "enum": [
            "nominal",
            "real"
          ],
          "title": "Discount Rate Basis",
          "type": "string"
        },
        "period_frequency": {
          "default": "annual",
          "enum": [
            "monthly",
            "quarterly",
            "annual"
          ],
          "title": "Period Frequency",
          "type": "string"
        },
        "time_basis": {
          "const": "end_of_period",
          "default": "end_of_period",
          "title": "Time Basis",
          "type": "string"
        },
        "rounding_policy": {
          "const": "half_up",
          "default": "half_up",
          "title": "Rounding Policy",
          "type": "string"
        },
        "monetary_decimals": {
          "default": 2,
          "maximum": 6,
          "minimum": 0,
          "title": "Monetary Decimals",
          "type": "integer"
        },
        "ratio_decimals": {
          "default": 4,
          "maximum": 6,
          "minimum": 0,
          "title": "Ratio Decimals",
          "type": "integer"
        }
      },
      "title": "CashFlowContext",
      "type": "object"
    },
    "CashFlowLine": {
      "additionalProperties": false,
      "properties": {
        "flow_id": {
          "maxLength": 100,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_-]+$",
          "title": "Flow Id",
          "type": "string"
        },
        "label": {
          "maxLength": 240,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "category": {
          "enum": [
            "capital_cost",
            "operating_cost",
            "revenue",
            "savings",
            "avoided_cost",
            "grant",
            "rebate",
            "residual_value",
            "decommissioning_cost",
            "working_capital",
            "working_capital_recovery",
            "other_benefit",
            "other_cost"
          ],
          "title": "Category",
          "type": "string"
        },
        "amount": {
          "minimum": 0,
          "title": "Amount",
          "type": "number",
          "x-unit": "currency"
        },
        "start_period": {
          "minimum": 0,
          "title": "Start Period",
          "type": "integer"
        },
        "end_period": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Period"
        },
        "interval_periods": {
          "default": 1,
          "minimum": 1,
          "title": "Interval Periods",
          "type": "integer"
        },
        "escalation_rate_percent_annual": {
          "default": 0,
          "exclusiveMinimum": -100,
          "maximum": 1000,
          "title": "Escalation Rate Percent Annual",
          "type": "number",
          "x-unit": "percent_per_year"
        },
        "price_basis": {
          "default": "nominal",
          "enum": [
            "nominal",
            "real"
          ],
          "title": "Price Basis",
          "type": "string"
        },
        "notes": {
          "default": "",
          "maxLength": 4000,
          "title": "Notes",
          "type": "string"
        }
      },
      "required": [
        "flow_id",
        "label",
        "category",
        "amount",
        "start_period"
      ],
      "title": "CashFlowLine",
      "type": "object"
    },
    "CashFlowScenarioInput": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "const": "1.7.0",
          "default": "1.7.0",
          "title": "Contract Version",
          "type": "string"
        },
        "model_id": {
          "const": "catalyst-finance.cash-flow",
          "default": "catalyst-finance.cash-flow",
          "title": "Model Id",
          "type": "string"
        },
        "project": {
          "$ref": "#/$defs/FinanceProject"
        },
        "context": {
          "$ref": "#/$defs/CashFlowContext"
        },
        "analysis_horizon_periods": {
          "maximum": 1200,
          "minimum": 1,
          "title": "Analysis Horizon Periods",
          "type": "integer"
        },
        "discount_rate_percent_annual": {
          "exclusiveMinimum": -100,
          "maximum": 1000,
          "title": "Discount Rate Percent Annual",
          "type": "number",
          "x-unit": "percent_per_year"
        },
        "finance_rate_percent_annual": {
          "default": 0,
          "exclusiveMinimum": -100,
          "maximum": 1000,
          "title": "Finance Rate Percent Annual",
          "type": "number",
          "x-unit": "percent_per_year"
        },
        "reinvestment_rate_percent_annual": {
          "default": 0,
          "exclusiveMinimum": -100,
          "maximum": 1000,
          "title": "Reinvestment Rate Percent Annual",
          "type": "number",
          "x-unit": "percent_per_year"
        },
        "lines": {
          "items": {
            "$ref": "#/$defs/CashFlowLine"
          },
          "maxItems": 1000,
          "minItems": 1,
          "title": "Lines",
          "type": "array"
        }
      },
      "required": [
        "project",
        "analysis_horizon_periods",
        "discount_rate_percent_annual",
        "lines"
      ],
      "title": "CashFlowScenarioInput",
      "type": "object"
    },
    "FinanceContext": {
      "additionalProperties": false,
      "properties": {
        "currency": {
          "default": "USD",
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "price_basis": {
          "default": "nominal",
          "enum": [
            "nominal",
            "real"
          ],
          "title": "Price Basis",
          "type": "string"
        },
        "discount_rate_basis": {
          "default": "nominal",
          "enum": [
            "nominal",
            "real"
          ],
          "title": "Discount Rate Basis",
          "type": "string"
        },
        "period_frequency": {
          "const": "annual",
          "default": "annual",
          "title": "Period Frequency",
          "type": "string"
        },
        "time_basis": {
          "const": "end_of_period",
          "default": "end_of_period",
          "title": "Time Basis",
          "type": "string"
        },
        "rounding_policy": {
          "const": "half_up",
          "default": "half_up",
          "title": "Rounding Policy",
          "type": "string"
        },
        "monetary_decimals": {
          "const": 2,
          "default": 2,
          "title": "Monetary Decimals",
          "type": "integer"
        },
        "ratio_decimals": {
          "const": 2,
          "default": 2,
          "title": "Ratio Decimals",
          "type": "integer"
        },
        "score_decimals": {
          "const": 1,
          "default": 1,
          "title": "Score Decimals",
          "type": "integer"
        }
      },
      "title": "FinanceContext",
      "type": "object"
    },
    "FinanceInputs": {
      "additionalProperties": false,
      "properties": {
        "capital_cost": {
          "minimum": 0,
          "title": "Capital Cost",
          "type": "number",
          "x-unit": "currency"
        },
        "external_funding": {
          "minimum": 0,
          "title": "External Funding",
          "type": "number",
          "x-unit": "currency"
        },
        "annual_savings": {
          "minimum": 0,
          "title": "Annual Savings",
          "type": "number",
          "x-unit": "currency"
        },
        "annual_operating_cost": {
          "minimum": 0,
          "title": "Annual Operating Cost",
          "type": "number",
          "x-unit": "currency"
        },
        "time_horizon_years": {
          "exclusiveMinimum": 0,
          "maximum": 100,
          "title": "Time Horizon Years",
          "type": "number",
          "x-unit": "years"
        },
        "discount_rate_percent": {
          "exclusiveMinimum": -100,
          "maximum": 100,
          "title": "Discount Rate Percent",
          "type": "number",
          "x-unit": "percent_per_year"
        },
        "annual_emissions_reduced_tons": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Annual Emissions Reduced Tons",
          "x-unit": "metric_tons_co2e_per_year"
        },
        "carbon_price_per_ton": {
          "default": 0,
          "minimum": 0,
          "title": "Carbon Price Per Ton",
          "type": "number",
          "x-unit": "currency_per_metric_ton_co2e"
        },
        "confidence_percent": {
          "maximum": 100,
          "minimum": 0,
          "title": "Confidence Percent",
          "type": "number",
          "x-unit": "percent"
        },
        "implementation_risk_percent": {
          "maximum": 100,
          "minimum": 0,
          "title": "Implementation Risk Percent",
          "type": "number",
          "x-unit": "percent"
        }
      },
      "required": [
        "capital_cost",
        "external_funding",
        "annual_savings",
        "annual_operating_cost",
        "time_horizon_years",
        "discount_rate_percent",
        "confidence_percent",
        "implementation_risk_percent"
      ],
      "title": "FinanceInputs",
      "type": "object"
    },
    "FinanceProject": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "category": {
          "default": "Sustainability finance",
          "maxLength": 120,
          "minLength": 1,
          "title": "Category",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "FinanceProject",
      "type": "object"
    },
    "FinanceScenarioInput": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "const": "1.7.0",
          "default": "1.7.0",
          "title": "Contract Version",
          "type": "string"
        },
        "model_id": {
          "const": "catalyst-finance.screening",
          "default": "catalyst-finance.screening",
          "title": "Model Id",
          "type": "string"
        },
        "project": {
          "$ref": "#/$defs/FinanceProject"
        },
        "context": {
          "$ref": "#/$defs/FinanceContext"
        },
        "assumptions": {
          "$ref": "#/$defs/FinanceInputs"
        }
      },
      "required": [
        "project",
        "assumptions"
      ],
      "title": "FinanceScenarioInput",
      "type": "object"
    },
    "ScenarioRevision": {
      "additionalProperties": false,
      "properties": {
        "revision_id": {
          "maxLength": 100,
          "minLength": 5,
          "pattern": "^[a-z]+_[A-Za-z0-9_-]+$",
          "title": "Revision Id",
          "type": "string"
        },
        "revision_number": {
          "minimum": 1,
          "title": "Revision Number",
          "type": "integer"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "model_id": {
          "default": "catalyst-finance.screening",
          "enum": [
            "catalyst-finance.screening",
            "catalyst-finance.cash-flow"
          ],
          "title": "Model Id",
          "type": "string"
        },
        "model_version": {
          "const": "1.7.0",
          "default": "1.7.0",
          "title": "Model Version",
          "type": "string"
        },
        "change_note": {
          "default": "",
          "maxLength": 1000,
          "title": "Change Note",
          "type": "string"
        },
        "scenario": {
          "anyOf": [
            {
              "$ref": "#/$defs/FinanceScenarioInput"
            },
            {
              "$ref": "#/$defs/CashFlowScenarioInput"
            }
          ],
          "title": "Scenario"
        }
      },
      "required": [
        "revision_id",
        "revision_number",
        "created_at",
        "scenario"
      ],
      "title": "ScenarioRevision",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "scenario_id": {
      "maxLength": 100,
      "minLength": 5,
      "pattern": "^[a-z]+_[A-Za-z0-9_-]+$",
      "title": "Scenario Id",
      "type": "string"
    },
    "project_id": {
      "anyOf": [
        {
          "maxLength": 100,
          "minLength": 5,
          "pattern": "^[a-z]+_[A-Za-z0-9_-]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Project Id"
    },
    "name": {
      "maxLength": 200,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "alternative_label": {
      "default": "Base",
      "maxLength": 120,
      "minLength": 1,
      "title": "Alternative Label",
      "type": "string"
    },
    "status": {
      "default": "active",
      "enum": [
        "draft",
        "active",
        "archived"
      ],
      "title": "Status",
      "type": "string"
    },
    "template_id": {
      "anyOf": [
        {
          "maxLength": 100,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Template Id"
    },
    "notes": {
      "default": "",
      "maxLength": 10000,
      "title": "Notes",
      "type": "string"
    },
    "tags": {
      "items": {
        "maxLength": 80,
        "minLength": 1,
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "archived_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Archived At"
    },
    "current_revision_id": {
      "maxLength": 100,
      "minLength": 5,
      "pattern": "^[a-z]+_[A-Za-z0-9_-]+$",
      "title": "Current Revision Id",
      "type": "string"
    },
    "revisions": {
      "items": {
        "$ref": "#/$defs/ScenarioRevision"
      },
      "minItems": 1,
      "title": "Revisions",
      "type": "array"
    }
  },
  "required": [
    "scenario_id",
    "name",
    "created_at",
    "updated_at",
    "current_revision_id",
    "revisions"
  ],
  "title": "WorkspaceScenario",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-finance/1.7.0/finance_workspace_scenario.schema.json"
}
